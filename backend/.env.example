# .env.example
# ==========================================
# CÓMO USAR EN PRODUCCIÓN:
# ==========================================
# 1. Copiar este archivo y nombrarlo como variables de entorno del sistema operativo (.env o setx en Windows)
# 2. Reemplazar los valores con credenciales reales seguras.
# ==========================================

# Base de Datos SQL Server
# El formato esperado en .NET para ConnectionStrings es ConnectionStrings__Name
# Equivalente en .NET: builder.Configuration.GetConnectionString("DefaultConnection")
ConnectionStrings__DefaultConnection="Server=localhost;Database=MembranaEchesortuDB;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true;"

# Json Web Tokens (Autenticación)
# Equivalente en .NET: builder.Configuration["Jwt:Key"]
Jwt__Key="+fGdUxLeMge9uRbMUF2qycBIj/PENro7lSBwCmmeBmkc="
Jwt__Issuer="MembranaEchesortu.API"
Jwt__Audience="MembranaEchesortu.Frontend"
Jwt__ExpirationMinutes=480

# CORS
# Permitir dominios específicos separados por comas
Cors__AllowedOrigins="http://localhost:5173,https://tudominio.com"
